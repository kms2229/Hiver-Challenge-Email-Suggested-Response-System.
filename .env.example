# Copy this file to .env and fill in your API key
# ─────────────────────────────────────────────────────────────────
# OpenAI (required for generation + embeddings + evaluation)
OPENAI_API_KEY=sk-...

# Optional: point at a local vLLM instance instead of api.openai.com
# vLLM serves an OpenAI-compatible API, so zero code changes needed —
# just set these two vars and point at your local vLLM server.
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=fake-key-for-local-vllm

# ─────────────────────────────────────────────────────────────────
# Model selection
EMBEDDING_MODEL=text-embedding-3-small
GENERATION_MODEL=gpt-4o-mini
JUDGE_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────────
# Dataset
DATA_PATH=data/emails.json

# ─────────────────────────────────────────────────────────────────
# RAG settings
RAG_TOP_K=3

# Agentic RAG: if best retrieval similarity < this threshold, the agent
# reformulates the query and retrieves again. Set to 0 to disable.
AGENTIC_RAG_THRESHOLD=0.60

# ─────────────────────────────────────────────────────────────────
# Generation modes (used when --mode is set in CLI)

# Self-Refine: generate → self-critique → revise (used with --mode refine)
# No extra config needed — 2 extra API calls per email.

# Mixture-of-Agents: number of independent candidate replies to generate
# before the synthesizer merges them (used with --mode moa)
MOA_CANDIDATES=3

# Agent-Agent Debate: number of Composer↔Critic debate rounds
# (used with --mode debate)
DEBATE_ROUNDS=2

# ─────────────────────────────────────────────────────────────────
# Evaluation settings

# Debate-as-Judge: use two independent judge agents that debate scoring
# instead of a single judge. More robust but ~2-3x more API calls.
# Set to true to enable.
USE_DEBATE_JUDGE=false
